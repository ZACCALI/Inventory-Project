generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  password          String
  role              String             @default("staff")
  avatar            String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  auditLogs         AuditLog[]
  notifications     Notification[]
  orders            Order[]
  pushSubscriptions PushSubscription[]
  stockLogs         StockLog[]
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Unit {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  customerType  String   @default("wholesale")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]

  @@index([name])
}

model Product {
  id         String       @id @default(cuid())
  name       String
  sku        String       @unique
  barcode    String?      @unique
  price      Float        @default(0)
  costPrice  Float        @default(0)
  stock      Int          @default(0)
  minStock   Int          @default(10)
  unit       String       @default("pcs")
  expiryDate DateTime?
  image      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  isArchived Boolean      @default(false)
  categoryId String?
  batches    Batch[]
  orderItems OrderItem[]
  category   Category?    @relation(fields: [categoryId], references: [id])
  uoms       ProductUOM[]
  stockLogs  StockLog[]

  @@index([categoryId])
  @@index([isArchived])
  @@index([stock])
  @@index([barcode])
  @@index([name])
}

model Batch {
  id          String     @id @default(cuid())
  batchNumber String?
  stock       Int
  initialQty  Int
  expiryDate  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  productId   String
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockLogs   StockLog[]

  @@index([productId])
  @@index([expiryDate])
}

model StockLog {
  id        String   @id @default(cuid())
  type      String
  quantity  Int
  reason    String?
  source    String   @default("MANUAL")
  isVoided  Boolean  @default(false)
  createdAt DateTime @default(now())
  productId String
  batchId   String?
  userId    String?
  batch     Batch?   @relation(fields: [batchId], references: [id])
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  totalAmount   Float       @default(0)
  status        String      @default("pending")
  paymentStatus String      @default("unpaid")
  orderType     String      @default("wholesale")
  discount      Float       @default(0)
  notes         String?
  orderDate     DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  isArchived    Boolean     @default(false)
  customerId    String
  createdById   String?
  delivery      Delivery?
  createdBy     User?       @relation(fields: [createdById], references: [id])
  customer      Customer    @relation(fields: [customerId], references: [id])
  items         OrderItem[]
  payments      Payment[]

  @@index([customerId])
  @@index([createdById])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderType])
  @@index([createdAt])
  @@index([isArchived])
}

model OrderItem {
  id         String  @id @default(cuid())
  quantity   Int
  price      Float
  subtotal   Float
  uomName    String?
  multiplier Int?
  orderId    String
  productId  String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  method    String   @default("cash")
  reference String?
  notes     String?
  createdAt DateTime @default(now())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Delivery {
  id            String    @id @default(cuid())
  driverName    String?
  driverPhone   String?
  scheduledDate DateTime?
  deliveredAt   DateTime?
  status        String    @default("pending")
  proofPhoto    String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orderId       String    @unique
  driverId      String?
  driver        Driver?   @relation(fields: [driverId], references: [id])
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([driverId])
}

model Driver {
  id          String     @id @default(cuid())
  name        String
  phone       String?
  vehicleInfo String?
  status      String     @default("active")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deliveries  Delivery[]
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  amount      Float
  category    String
  description String
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@index([createdAt])
}

model OrderReference {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSettings {
  id                 String   @id @default("1")
  companyName        String   @default("My Company")
  email              String?
  phone              String?
  address            String?
  currency           String   @default("PHP")
  taxRate            Float    @default(0)
  expiryWarningDays  Int      @default(30)
  cleanupMode        Boolean  @default(false)
  lockProductDelete  Boolean  @default(true)
  lockProductEdit    Boolean  @default(false)
  lockOrderDelete    Boolean  @default(true)
  lockOrderEdit      Boolean  @default(false)
  lockOrderCancel    Boolean  @default(false)
  lockOrderDate      Boolean  @default(false)
  lockStockVoid      Boolean  @default(false)
  stockInReasons     String   @default("[\"New Stock Delivery\",\"Customer Return\",\"Inventory Adjustment\",\"Transfer In\",\"Other\"]")
  stockOutReasons    String   @default("[\"Damage/Spoilage\",\"Expired\",\"Internal Use\",\"Inventory Adjustment\",\"Customer Order\",\"Transfer Out\",\"Other\"]")
  staffPermissions   String   @default("inventory,stock,delivery,drivers,history")
  cashierPermissions String   @default("customers,orders")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  expenseCategories  String   @default("[\"Rent & Lease\",\"Utilities\",\"Payroll & Salary\",\"Office Supplies\",\"Marketing\",\"Maintenance\",\"Transportation\",\"Other\"]")
  printerName        String?
  paperWidth         String   @default("58")
  autoPrintOrder     Boolean  @default(false)
  connectionType     String   @default("qz")
  printerIp          String?
  printerPort        String?
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  details   String
  createdAt DateTime @default(now())
  mode      String   @default("online")
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@index([mode])
}

model ProductUOM {
  id         String  @id @default(cuid())
  name       String
  barcode    String? @unique
  multiplier Int
  price      Float
  isBase     Boolean @default(false)
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String
  link        String?
  isRead      Boolean  @default(false)
  isDismissed Boolean  @default(false)
  referenceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDismissed])
  @@index([userId, referenceId, type, isDismissed])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model IdempotencyRecord {
  key       String   @id
  createdAt DateTime @default(now())

  @@index([createdAt])
}
