// DistriTrack Database Schema
// Using PostgreSQL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("staff") // admin, staff, cashier
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockLogs StockLog[]
  orders    Order[]
  auditLogs AuditLog[]
  notifications Notification[]
  pushSubscriptions PushSubscription[]
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]
}

model Unit {
  id          String    @id @default(cuid())
  name        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}


model Customer {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  customerType  String   @default("wholesale") // wholesale, walk-in
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]

  @@index([name])
}

model Product {
  id         String    @id @default(cuid())
  name       String
  sku        String    @unique
  barcode    String?   @unique
  price      Float     @default(0)
  costPrice  Float     @default(0)
  stock      Int       @default(0)
  minStock   Int       @default(10)
  unit       String    @default("pcs")
  expiryDate DateTime?
  image      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  isArchived Boolean   @default(false)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])


  stockLogs  StockLog[]
  orderItems OrderItem[]
  batches    Batch[]
  uoms       ProductUOM[]

  @@index([categoryId])
  @@index([isArchived])
  @@index([stock])
  @@index([barcode])
  @@index([name])
}

model Batch {
  id          String    @id @default(cuid())
  batchNumber String?
  stock       Int       // Current remaining stock in this batch
  initialQty  Int       // How much was originally received
  expiryDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  stockLogs  StockLog[]

  @@index([productId])
  @@index([expiryDate])
}

model StockLog {
  id        String   @id @default(cuid())
  type      String   // IN or OUT
  quantity  Int
  reason    String?
  source    String   @default("MANUAL")
  isVoided  Boolean  @default(false)
  createdAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  batchId   String?
  batch     Batch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Order {
  id            String   @id @default(cuid())
  orderNumber   String   @unique
  totalAmount   Float    @default(0)
  status        String   @default("pending") // pending, confirmed, delivered, cancelled
  paymentStatus String   @default("unpaid")  // unpaid, partial, paid
  orderType     String   @default("wholesale") // wholesale, pos
  discount      Float    @default(0)
  notes         String?
  orderDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isArchived    Boolean  @default(false)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  items    OrderItem[]
  payments  Payment[]
  delivery Delivery?

  @@index([customerId])
  @@index([createdById])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderType])
  @@index([createdAt])
  @@index([isArchived])
}

model OrderItem {
  id       String @id @default(cuid())
  quantity Int
  price    Float
  subtotal Float
  uomName  String?
  multiplier Int?

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  method    String   @default("cash") // cash, gcash, bank_transfer, check
  reference String?  // transaction reference number
  notes     String?
  createdAt DateTime @default(now())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Delivery {
  id            String    @id @default(cuid())
  driverName    String?
  driverPhone   String?
  scheduledDate DateTime?
  deliveredAt   DateTime?
  status        String    @default("pending") // pending, in_transit, delivered, failed, cancelled
  proofPhoto    String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orderId  String  @unique
  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([driverId])
}

model Driver {
  id          String     @id @default(cuid())
  name        String
  phone       String?
  vehicleInfo String?
  status      String     @default("active") // active, inactive
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  deliveries  Delivery[]
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  amount      Float
  category    String
  description String
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@index([createdAt])
}

model OrderReference {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSettings {
  id                    String   @id @default("1")
  companyName           String   @default("My Company")
  email                 String?
  phone                 String?
  address               String?
  currency              String   @default("PHP")
  taxRate               Float    @default(0)
  expiryWarningDays     Int      @default(30)
  cleanupMode           Boolean  @default(false)
  lockProductDelete     Boolean  @default(true)
  lockProductEdit       Boolean  @default(false)
  lockOrderDelete       Boolean  @default(true)
  lockOrderEdit         Boolean  @default(false)
  lockOrderCancel       Boolean  @default(false)
  lockOrderDate         Boolean  @default(false)
  lockStockVoid         Boolean  @default(false)
  stockInReasons        String   @default("[\"New Stock Delivery\",\"Customer Return\",\"Inventory Adjustment\",\"Transfer In\",\"Other\"]")
  stockOutReasons       String   @default("[\"Damage/Spoilage\",\"Expired\",\"Internal Use\",\"Inventory Adjustment\",\"Customer Order\",\"Transfer Out\",\"Other\"]")
  expenseCategories     String   @default("[\"Rent & Lease\",\"Utilities\",\"Payroll & Salary\",\"Office Supplies\",\"Marketing\",\"Maintenance\",\"Transportation\",\"Other\"]")
  staffPermissions      String   @default("inventory,stock,delivery,drivers,history")
  cashierPermissions    String   @default("customers,orders")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g., "CREATE", "UPDATE", "DELETE"
  entity    String   // e.g., "Order", "Expense", "Delivery"
  details   String   // JSON string or plain text description
  mode      String   @default("online") // "online" or "offline"
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@index([mode])
}

model ProductUOM {
  id         String   @id @default(cuid())
  name       String   // e.g., "Pack", "Box"
  barcode    String?  @unique
  multiplier Int      // "Pack" = 1, "Box" = 10
  price      Float    // Price for this specific unit
  isBase     Boolean  @default(false)
  
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String   
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "low_stock", "expiry", "delivery", "system"
  title       String
  message     String
  link        String?
  isRead      Boolean  @default(false)
  isDismissed Boolean  @default(false)
  referenceId String?  // e.g., productId, batchId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, isDismissed])
  @@index([userId, referenceId, type, isDismissed])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}
